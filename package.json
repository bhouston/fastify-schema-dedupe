{
  "name": "private-monorepo",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "start": "pnpm --filter basic-example start",
    "make-release": "node scripts/make-release.ts packages/fastify-schema-dedupe",
    "clean": "rimraf dist packages/**/dist demos/**/dist .nx node_modules packages/**/node_modules demos/**/node_modules",
    "format": "oxfmt .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "tsc": "tsgo -b",
    "tsgo": "pnpm -r tsgo",
    "test": "pnpm vitest",
    "bench": "vitest bench --run --no-file-parallelism",
    "cloc": "npx cloc * --exclude-dir=node_modules,dist,.nx,.next,build"
  },
  "devDependencies": {
    "@types/node": "^24",
    "@typescript/native-preview": "7.0.0-dev.20251229.1",
    "@vitest/coverage-v8": "4.1.2",
    "chalk": "^5.6.2",
    "glob": "^13.0.0",
    "husky": "^9.1.7",
    "jsonfile": "^6.2.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "prompt-confirm": "^2.0.4",
    "rimraf": "^6.0.1",
    "semver": "^7.7.3",
    "vitest": "4.1.2"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.17.0"
}
