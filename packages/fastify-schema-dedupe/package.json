  },
  "license": "MIT",
  "author": "Ben Houston <neuralsoft@gmail.com> (https://ben3d.ca)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bhouston/fastify-schema-dedupe"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
